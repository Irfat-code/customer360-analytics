# =============================================================================
# CUSTOMER360 INTELLIGENCE PLATFORM
# .gitignore
# =============================================================================

# Environment variables — never commit credentials
.env
*.env

# Logs
logs/
*.log

# Python
__pycache__/
*.py[cod]
*.egg-info/
venv/
.venv/

# dbt build artifacts — regenerated on every run
**/target/
**/dbt_packages/
**/logs/
**/.user.yml

# Docker
.docker/

# OS
.DS_Store
Thumbs.db

# VS Code
.vscode/

# Data files — can be large, generated by scripts
datasets/**/*.csv
datasets/**/*.json
datasets/**/*.parquet